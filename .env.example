# =========================
# CẤU HÌNH CHUNG
# =========================
# Múi giờ server/container
TZ=Asia/Ho_Chi_Minh

# =========================
# DATABASE (PostgreSQL)
# =========================
# Tài khoản DB dùng trong Docker Compose
POSTGRES_DB=erp_db
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=doi_mat_khau_manh

# Chuỗi kết nối cho ứng dụng Next.js + Prisma
DATABASE_URL=postgresql://erp_user:doi_mat_khau_manh@db:5432/erp_db

# =========================
# AUTH (NextAuth)
# =========================
# Secret ngẫu nhiên >= 32 ký tự (đổi khi deploy production)
NEXTAUTH_SECRET=doi_secret_ngau_nhien_it_nhat_32_ky_tu
# URL app ở môi trường dev local
NEXTAUTH_URL=http://localhost:3000
# Khi deploy production: đổi thành https://erp.huynhgia6.com

# =========================
# MINIO (Lưu ảnh công trường)
# =========================
# Root user/pass cho MinIO container
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=doi_minio_root_password

# Thông số app dùng để kết nối MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=doi_minio_root_password
MINIO_BUCKET=construction-photos

# =========================
# INTERNAL JOB (Cron endpoints)
# =========================
# Secret dùng để gọi các endpoint job nội bộ (/api/reports/jobs/*)
INTERNAL_JOB_SECRET=doi_secret_noi_bo_32_ky_tu

# Ví dụ scheduler gọi endpoint nội bộ (UTC):
# 01:00 -> 08:00 VN: POST /api/reports/jobs/reminders
# 12:00 -> 19:00 VN: POST /api/reports/jobs/reminders
# 16:59 -> 23:59 VN: POST /api/reports/jobs/kpi-snapshot
# 17:00 -> 00:00 VN: POST /api/reports/jobs/kpi-snapshot
# Header bắt buộc: x-internal-job-secret: $INTERNAL_JOB_SECRET

# =========================
# SMTP (Quên mật khẩu)
# =========================
# Phase 1 có thể để trống, sẽ cấu hình sau
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# =========================
# PRODUCTION DEPLOY (GỢI Ý)
# =========================
# File .env.production trên server nên chứa tối thiểu các biến:
# POSTGRES_DB, POSTGRES_USER, POSTGRES_PASSWORD
# NEXTAUTH_SECRET, NEXTAUTH_URL
# MINIO_ROOT_USER, MINIO_ROOT_PASSWORD
# MINIO_ENDPOINT, MINIO_ACCESS_KEY, MINIO_SECRET_KEY, MINIO_BUCKET
# INTERNAL_JOB_SECRET
#
# GitHub Actions deploy dùng Secrets (không đặt ở .env):
# PROD_SSH_HOST, PROD_SSH_PORT, PROD_SSH_USER
# PROD_SSH_PRIVATE_KEY, PROD_APP_DIR, PROD_KNOWN_HOSTS
