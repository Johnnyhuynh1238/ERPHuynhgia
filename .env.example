# =========================
# CẤU HÌNH CHUNG
# =========================
# Múi giờ server/container
TZ=Asia/Ho_Chi_Minh

# =========================
# DATABASE (PostgreSQL)
# =========================
# Tài khoản DB dùng trong Docker Compose
POSTGRES_DB=erp_db
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=doi_mat_khau_manh

# Chuỗi kết nối cho ứng dụng Next.js + Prisma
DATABASE_URL=postgresql://erp_user:doi_mat_khau_manh@db:5432/erp_db

# =========================
# AUTH (NextAuth)
# =========================
# Secret ngẫu nhiên >= 32 ký tự
NEXTAUTH_SECRET=doi_secret_ngau_nhien_it_nhat_32_ky_tu
# URL public của hệ thống (khi deploy thật sẽ là subdomain HTTPS)
NEXTAUTH_URL=https://erp.huynhgia6.com

# =========================
# MINIO (Lưu ảnh công trường)
# =========================
# Root user/pass cho MinIO container
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=doi_minio_root_password

# Thông số app dùng để kết nối MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=doi_minio_root_password
MINIO_BUCKET=construction-photos

# =========================
# SMTP (Quên mật khẩu)
# =========================
# Phase 1 có thể để trống, sẽ cấu hình sau
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
