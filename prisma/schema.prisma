model CustomerComment {
  id              String             @id @default(uuid()) @db.Uuid
  projectId       String             @map("project_id") @db.Uuid
  taskId          String?            @map("task_id") @db.Uuid
  eveningReportId String?            @map("evening_report_id") @db.Uuid
  targetType      CommentTargetType? @map("target_type")
  targetId        String?            @map("target_id") @db.Uuid
  authorType      String?            @map("author_type")
  authorId        String?            @map("author_id") @db.Uuid
  authorName      String?            @map("author_name")
  content         String             @db.Text
  parentId        String?            @map("parent_id") @db.Uuid
  ipAddress       String?            @map("ip_address")
  userAgent       String?            @map("user_agent")
  createdAt       DateTime           @default(now()) @map("created_at")
  readByStaff     Boolean            @default(false) @map("read_by_staff")

  project       Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task          Task?                  @relation(fields: [taskId], references: [id], onDelete: SetNull)
  eveningReport EveningReport?         @relation(fields: [eveningReportId], references: [id], onDelete: SetNull)
  author        User?                  @relation("CustomerCommentAuthor", fields: [authorId], references: [id])
  parent        CustomerComment?       @relation("CommentThread", fields: [parentId], references: [id])
  threadReplies CustomerComment[]      @relation("CommentThread")
  replies       CustomerCommentReply[]

  @@index([projectId])
  @@index([projectId, targetType, targetId])
  @@index([targetType, targetId, createdAt])
  @@index([taskId])
  @@index([eveningReportId])
  @@index([authorId])
  @@index([parentId])
  @@index([readByStaff])
  @@map("customer_comments")
}

