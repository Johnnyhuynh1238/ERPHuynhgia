// ──────────────────────────── M2: Dự toán công trình (NC + VT + MM) ────────────────────────────

enum BudgetCategory {
  labor
  material
  equipment
}

enum BudgetPhase {
  mong
  than
  mai
}

// 5 stage chuẩn cho dự toán theo cấu kiện (SOP-47)
enum BudgetStage {
  CB // Chuẩn bị
  N // Ngầm
  T // Thô
  HT // Hoàn thiện
  ME // M&E (điện nước, chống sét, thiết bị) — giá tra từ MePrice, không qua định mức
}

enum BudgetStatus {
  draft
  locked
}

enum AmendmentStatus {
  draft
  approved
  rejected
}

model ProjectBudget {
  id             String       @id @default(uuid()) @db.Uuid
  projectId      String       @unique @map("project_id") @db.Uuid
  status         BudgetStatus @default(draft)
  totalLabor     BigInt       @default(0) @map("total_labor")
  totalMaterial  BigInt       @default(0) @map("total_material")
  totalEquipment BigInt       @default(0) @map("total_equipment")
  totalAmount    BigInt       @default(0) @map("total_amount")
  note           String?
  createdById    String       @map("created_by_id") @db.Uuid
  lockedById     String?      @map("locked_by_id") @db.Uuid
  lockedAt       DateTime?    @map("locked_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  project    Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy  User                     @relation("ProjectBudgetCreator", fields: [createdById], references: [id])
  lockedBy   User?                    @relation("ProjectBudgetLocker", fields: [lockedById], references: [id])
  items      ProjectBudgetItem[]
  amendments ProjectBudgetAmendment[]

  @@index([status])
  @@map("project_budgets")
}

model ProjectBudgetItem {
  id             String         @id @default(uuid()) @db.Uuid
  budgetId       String         @map("budget_id") @db.Uuid
  category       BudgetCategory
  phase          BudgetPhase // DEPRECATED — giữ tạm cho compat; truy vấn mới dùng stage
  phaseCode      String         @default("02") @map("phase_code") @db.VarChar(2) // DEPRECATED — dùng stage
  standardTaskId String?        @map("standard_task_id") @db.Uuid // DEPRECATED — mã catalog không còn cố định
  name           String
  unit           String         @db.VarChar(20)
  quantity       Decimal        @db.Decimal(14, 3)
  unitPrice      BigInt         @map("unit_price") // DEPRECATED — dùng laborUnitPrice/materialUnitPrice/equipmentUnitPrice
  amount         BigInt // tổng giá vốn item = labor + material + equipment (khi dùng model mới)
  note           String?
  sortRank       Float          @default(0) @map("sort_rank")
  qcChecklist    Json?          @map("qc_checklist")
  breakdown      Json?          @db.JsonB // [{name, quantity, note?}] — công tác con
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  // Cấu kiện-centric model (SOP-47 v2)
  componentId        String?      @map("component_id") @db.Uuid
  stage              BudgetStage?
  laborUnitPrice     BigInt       @default(0) @map("labor_unit_price")
  laborAmount        BigInt       @default(0) @map("labor_amount")
  materialUnitPrice  BigInt       @default(0) @map("material_unit_price")
  materialAmount     BigInt       @default(0) @map("material_amount")
  equipmentUnitPrice BigInt       @default(0) @map("equipment_unit_price")
  equipmentAmount    BigInt       @default(0) @map("equipment_amount")

  // Định mức gắn vào công tác (global Norm.code) — dùng để tính hao phí VT/NC/MM
  normCode String? @map("norm_code") @db.VarChar(32)

  // Đơn giá trực tiếp (VND/đơn vị) — dùng cho item không qua định mức (sheet 6 cửa, item lump-sum).
  // Khi != null: amount = quantity × directUnitPrice, bỏ qua norm + MePrice.
  directUnitPrice BigInt? @map("direct_unit_price")

  budget       ProjectBudget        @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  standardTask StandardTaskCatalog? @relation(fields: [standardTaskId], references: [id], onDelete: SetNull)
  component    ProjectComponent?    @relation(fields: [componentId], references: [id], onDelete: SetNull)
  norm         Norm?                @relation(fields: [normCode], references: [code], onDelete: SetNull)
  workOrders   WorkOrder[]

  @@index([budgetId, category, phaseCode])
  @@index([budgetId, category, phase])
  @@index([standardTaskId])
  @@index([componentId])
  @@index([budgetId, stage])
  @@index([normCode])
  @@map("project_budget_items")
}

// Cấu kiện vật lý (móng, cột T1, tường bao T2…) — đơn vị bóc KL & dự toán
model ProjectComponent {
  id        String      @id @default(uuid()) @db.Uuid
  projectId String      @map("project_id") @db.Uuid
  stage     BudgetStage
  name      String
  floor     String?     @db.VarChar(8) // T1/T2/ST/M…; null cho cấu kiện không tầng
  sortOrder Int         @default(0) @map("sort_order")
  note      String?
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  project Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items   ProjectBudgetItem[]

  @@index([projectId, stage, sortOrder])
  @@map("project_components")
}

// ──────────────────────────── M2 v4: Định mức GLOBAL (SOP 47 — số liệu chung, K chỉnh sau) ────────────────────────────

// Định mức hao phí VT/NC/MM per 1 đơn vị công tác — GLOBAL (không buộc project),
// nguồn nhà nước (TT 12/13 BXD), K điều chỉnh khớp thực tế.
model Norm {
  id            String    @id @default(uuid()) @db.Uuid
  code          String    @unique @db.VarChar(32) // VD: "AF.11110" — mã công bố
  name          String // Tên công tác chuẩn
  unit          String    @db.VarChar(20) // m³, m², md, kg, tấn, công, ca…
  category      String?   @db.VarChar(64) // be_tong / cot_thep / cop_pha / xay / to_trat / op_lat / son / tran / chong_tham / khac
  materialItems Json      @default("[]") @map("material_items") @db.JsonB // [{name, unit, qtyPerUnit, note?}]
  laborItems    Json      @default("[]") @map("labor_items") @db.JsonB // [{grade, hoursPerUnit, note?}] — bậc thợ, công/đv
  machineItems  Json      @default("[]") @map("machine_items") @db.JsonB // [{name, hoursPerUnit, note?}] — loại máy, ca/đv
  kMaterial     Decimal   @default(1) @map("k_material") @db.Decimal(8, 4) // hệ số VT
  kLabor        Decimal   @default(1) @map("k_labor") @db.Decimal(8, 4) // hệ số NC
  kMachine      Decimal   @default(1) @map("k_machine") @db.Decimal(8, 4) // hệ số MM
  source        String?   @db.VarChar(255) // VD: "TT 12/2021 BXD"
  note          String?
  retiredAt     DateTime? @map("retired_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  budgetItems ProjectBudgetItem[]

  @@index([category])
  @@index([retiredAt])
  @@map("norms")
}

// Bảng giá M&E (thiết bị điện nước, chống sét…) — đơn vị bộ/cái/m, không qua định mức
model MePrice {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(255)
  unit      String    @db.VarChar(20)
  price     BigInt
  brand     String?   @db.VarChar(128) // Hãng/model: Inax, Panasonic, Cadivi…
  category  String?   @db.VarChar(64) // nuoc / dien / dien_nhe / dieu_hoa / chong_set
  source    String?   @db.VarChar(255)
  note      String?
  retiredAt DateTime? @map("retired_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@unique([name, unit])
  @@index([category])
  @@index([retiredAt])
  @@map("me_prices")
}

// Global price catalog — admin chỉnh khi tạo dự án mới
model MaterialPrice {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(255)
  unit      String    @db.VarChar(20)
  price     BigInt
  source    String?   @db.VarChar(255)
  note      String?
  retiredAt DateTime? @map("retired_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@unique([name, unit])
  @@index([retiredAt])
  @@map("material_prices")
}

model LaborPrice {
  id        String    @id @default(uuid()) @db.Uuid
  grade     String    @unique @db.VarChar(16)
  price     BigInt
  source    String?   @db.VarChar(255)
  note      String?
  retiredAt DateTime? @map("retired_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([retiredAt])
  @@map("labor_prices")
}

model MachinePrice {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @unique @db.VarChar(255)
  price     BigInt
  source    String?   @db.VarChar(255)
  note      String?
  retiredAt DateTime? @map("retired_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([retiredAt])
  @@map("machine_prices")
}

model ProjectBudgetAmendment {
  id             String          @id @default(uuid()) @db.Uuid
  budgetId       String          @map("budget_id") @db.Uuid
  reason         String
  deltaLabor     BigInt          @default(0) @map("delta_labor")
  deltaMaterial  BigInt          @default(0) @map("delta_material")
  deltaEquipment BigInt          @default(0) @map("delta_equipment")
  deltaAmount    BigInt          @default(0) @map("delta_amount")
  status         AmendmentStatus @default(draft)
  proposedById   String          @map("proposed_by_id") @db.Uuid
  approvedById   String?         @map("approved_by_id") @db.Uuid
  approvedAt     DateTime?       @map("approved_at")
  rejectReason   String?         @map("reject_reason")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  budget     ProjectBudget                @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  proposedBy User                         @relation("ProjectBudgetAmendmentProposer", fields: [proposedById], references: [id])
  approvedBy User?                        @relation("ProjectBudgetAmendmentApprover", fields: [approvedById], references: [id])
  items      ProjectBudgetAmendmentItem[]

  @@index([budgetId, status])
  @@map("project_budget_amendments")
}

model ProjectBudgetAmendmentItem {
  id          String         @id @default(uuid()) @db.Uuid
  amendmentId String         @map("amendment_id") @db.Uuid
  category    BudgetCategory
  phase       BudgetPhase // DEPRECATED — giữ tạm cho compat
  phaseCode   String         @default("02") @map("phase_code") @db.VarChar(2)
  name        String
  unit        String         @db.VarChar(20)
  quantity    Decimal        @db.Decimal(14, 3)
  unitPrice   BigInt         @map("unit_price")
  amount      BigInt
  note        String?
  createdAt   DateTime       @default(now()) @map("created_at")

  amendment ProjectBudgetAmendment @relation(fields: [amendmentId], references: [id], onDelete: Cascade)

  @@index([amendmentId, category, phaseCode])
  @@index([amendmentId, category, phase])
  @@map("project_budget_amendment_items")
}

// ──────────────────────────── M3: Phiếu giao việc hàng ngày ────────────────────────────

enum WorkOrderStatus {
  open
  done
  carried
}

model WorkOrder {
  id           String          @id @default(uuid()) @db.Uuid
  projectId    String          @map("project_id") @db.Uuid
  date         DateTime        @db.Date
  groupNo      Int             @map("group_no")
  budgetItemId String          @map("budget_item_id") @db.Uuid
  workItem     String          @map("work_item")
  unit         String          @db.VarChar(20)
  unitPrice    BigInt          @map("unit_price")
  targetQty    Decimal         @map("target_qty") @db.Decimal(14, 3)
  techNote     String?         @map("tech_note")
  status       WorkOrderStatus @default(open)
  createdById  String          @map("created_by_id") @db.Uuid
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetItem ProjectBudgetItem @relation(fields: [budgetItemId], references: [id])
  createdBy  User              @relation("WorkOrderCreatedBy", fields: [createdById], references: [id])
  workers    WorkOrderWorker[]
  output     WorkOrderOutput?

  @@unique([projectId, date, groupNo])
  @@index([projectId, date])
  @@index([budgetItemId])
  @@map("work_orders")
}

model WorkOrderWorker {
  id          String   @id @default(uuid()) @db.Uuid
  workOrderId String   @map("work_order_id") @db.Uuid
  workerId    String   @map("worker_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  worker    Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([workOrderId, workerId])
  @@index([workerId])
  @@map("work_order_workers")
}

// ──────────────────────────── M4: Chấm công cuối ngày + sản lượng ────────────────────────────

enum TimesheetAbsentReason {
  P // có phép
  KP // không phép
  MUA // mưa - lỗi công ty, loại khỏi mẫu số đánh giá
  CHO // chờ việc - lỗi công ty, loại khỏi mẫu số
}

enum WorkOrderOutputQcStatus {
  pending
  passed
  failed
  rework
}

model WorkerTimesheet {
  id           String                 @id @default(uuid()) @db.Uuid
  projectId    String                 @map("project_id") @db.Uuid
  workerId     String                 @map("worker_id") @db.Uuid
  date         DateTime               @db.Date
  dayValue     Decimal                @map("day_value") @db.Decimal(3, 2)
  absentReason TimesheetAbsentReason? @map("absent_reason")
  weekKey      String                 @map("week_key") @db.VarChar(10)
  note         String?
  createdById  String                 @map("created_by_id") @db.Uuid
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  worker    Worker  @relation(fields: [workerId], references: [id], onDelete: Cascade)
  createdBy User    @relation("WorkerTimesheetCreatedBy", fields: [createdById], references: [id])

  @@unique([workerId, date])
  @@index([projectId, date])
  @@index([projectId, weekKey])
  @@map("worker_timesheets")
}

model WorkOrderOutput {
  id           String                  @id @default(uuid()) @db.Uuid
  workOrderId  String                  @unique @map("work_order_id") @db.Uuid
  projectId    String                  @map("project_id") @db.Uuid
  date         DateTime                @db.Date
  actualQty    Decimal                 @map("actual_qty") @db.Decimal(14, 3)
  approvedQty  Decimal?                @map("approved_qty") @db.Decimal(14, 3)
  qcStatus     WorkOrderOutputQcStatus @default(pending) @map("qc_status")
  weekKey      String                  @map("week_key") @db.VarChar(10)
  note         String?
  createdById  String                  @map("created_by_id") @db.Uuid
  approvedById String?                 @map("approved_by_id") @db.Uuid
  approvedAt   DateTime?               @map("approved_at")
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")

  workOrder  WorkOrder                @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  project    Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy  User                     @relation("WorkOrderOutputCreatedBy", fields: [createdById], references: [id])
  approvedBy User?                    @relation("WorkOrderOutputApprovedBy", fields: [approvedById], references: [id])
  photos     WorkOrderOutputPhoto[]
  qcChecks   WorkOrderOutputQcCheck[]
  qcIssues   WorkerQcIssue[]

  @@index([projectId, date])
  @@index([projectId, weekKey])
  @@index([qcStatus])
  @@map("work_order_outputs")
}

model WorkOrderOutputPhoto {
  id           String   @id @default(uuid()) @db.Uuid
  outputId     String   @map("output_id") @db.Uuid
  storageKey   String   @map("storage_key")
  width        Int?
  height       Int?
  sizeBytes    Int?     @map("size_bytes")
  contentType  String?  @map("content_type") @db.VarChar(60)
  sortRank     Float    @default(0) @map("sort_rank")
  uploadedById String   @map("uploaded_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  output     WorkOrderOutput @relation(fields: [outputId], references: [id], onDelete: Cascade)
  uploadedBy User            @relation("WorkOrderOutputPhotoUploadedBy", fields: [uploadedById], references: [id])

  @@index([outputId, sortRank])
  @@map("work_order_output_photos")
}

enum WorkOrderOutputQcCheckStatus {
  pending
  passed
  failed
}

enum WorkerQcIssueSeverity {
  minor
  major
  critical
}

model WorkOrderOutputQcCheck {
  id          String                       @id @default(uuid()) @db.Uuid
  outputId    String                       @map("output_id") @db.Uuid
  itemIndex   Int                          @map("item_index")
  itemTitle   String                       @map("item_title")
  status      WorkOrderOutputQcCheckStatus @default(pending)
  photoKey    String?                      @map("photo_key")
  note        String?
  checkedById String?                      @map("checked_by_id") @db.Uuid
  checkedAt   DateTime?                    @map("checked_at")
  createdAt   DateTime                     @default(now()) @map("created_at")
  updatedAt   DateTime                     @updatedAt @map("updated_at")

  output    WorkOrderOutput @relation(fields: [outputId], references: [id], onDelete: Cascade)
  checkedBy User?           @relation("WorkOrderOutputQcCheckCheckedBy", fields: [checkedById], references: [id])

  @@unique([outputId, itemIndex])
  @@index([outputId, status])
  @@map("work_order_output_qc_checks")
}

model WorkerQcIssue {
  id          String                @id @default(uuid()) @db.Uuid
  workerId    String                @map("worker_id") @db.Uuid
  outputId    String?               @map("output_id") @db.Uuid
  projectId   String                @map("project_id") @db.Uuid
  severity    WorkerQcIssueSeverity
  reason      String
  occurredAt  DateTime              @map("occurred_at") @db.Date
  createdById String                @map("created_by_id") @db.Uuid
  createdAt   DateTime              @default(now()) @map("created_at")

  worker    Worker           @relation(fields: [workerId], references: [id], onDelete: Cascade)
  output    WorkOrderOutput? @relation(fields: [outputId], references: [id], onDelete: SetNull)
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User             @relation("WorkerQcIssueCreatedBy", fields: [createdById], references: [id])

  @@index([workerId, occurredAt])
  @@index([projectId, occurredAt])
  @@map("worker_qc_issues")
}

// ─── M6 Bảng lương tuần tự động ──────────────────────────────────────────────

enum WeeklyPayrollStatus {
  draft
  ready_to_pay
  paid
}

model WeeklyPayroll {
  id        String              @id @default(uuid()) @db.Uuid
  projectId String              @map("project_id") @db.Uuid
  weekKey   String              @map("week_key") // ISO YYYY-Www
  weekStart DateTime            @map("week_start") @db.Date
  weekEnd   DateTime            @map("week_end") @db.Date
  status    WeeklyPayrollStatus @default(draft)

  // Snapshot tổng tại thời điểm Chốt tuần. Lưu cứng để KETOAN ko bị ảnh hưởng
  // khi ai đó sửa lại Timesheet/Output sau khi chốt.
  totalDays        Decimal @map("total_days") @db.Decimal(10, 2)
  totalDailyWage   BigInt  @map("total_daily_wage")
  totalOutputValue BigInt  @map("total_output_value")
  weekDelta        BigInt  @map("week_delta") // có thể âm
  carryoverPrev    BigInt  @map("carryover_prev") // sau khi cộng dồn từ tuần trước
  carryoverNew     BigInt  @map("carryover_new") // còn lại sau khi chia thưởng (≥0)
  bonusPool        BigInt  @map("bonus_pool")
  shareRate        Decimal @map("share_rate") @db.Decimal(5, 4)
  totalBonus       BigInt  @map("total_bonus")
  totalPayable     BigInt  @map("total_payable") // lương + thưởng

  // Cảnh báo: số tuần âm liên tiếp (đã trừ tuần MUA/CHO đa số)
  negStreak Int @default(0) @map("neg_streak")

  note        String?
  closedById  String    @map("closed_by_id") @db.Uuid
  closedAt    DateTime  @default(now()) @map("closed_at")
  readiedById String?   @map("readied_by_id") @db.Uuid
  readiedAt   DateTime? @map("readied_at")
  paidById    String?   @map("paid_by_id") @db.Uuid
  paidAt      DateTime? @map("paid_at")
  paidNote    String?   @map("paid_note")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project     Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  closedBy    User                      @relation("WeeklyPayrollClosedBy", fields: [closedById], references: [id])
  readiedBy   User?                     @relation("WeeklyPayrollReadiedBy", fields: [readiedById], references: [id])
  paidBy      User?                     @relation("WeeklyPayrollPaidBy", fields: [paidById], references: [id])
  lines       WeeklyPayrollLine[]
  adjustments WeeklyPayrollAdjustment[]

  @@unique([projectId, weekKey])
  @@index([projectId, status])
  @@map("weekly_payrolls")
}

model WeeklyPayrollLine {
  id        String @id @default(uuid()) @db.Uuid
  payrollId String @map("payroll_id") @db.Uuid
  workerId  String @map("worker_id") @db.Uuid

  // Snapshot lúc chốt
  fullName    String  @map("full_name")
  grade       Int?
  bankAccount String? @map("bank_account")
  bankName    String? @map("bank_name")
  phone       String?

  totalDays  Decimal @map("total_days") @db.Decimal(10, 2)
  dailyRate  BigInt  @map("daily_rate")
  dailyWage  BigInt  @map("daily_wage")
  bonus      BigInt
  adjustment BigInt  @default(0) // điều chỉnh tay tuần này (âm/dương)
  payable    BigInt // dailyWage + bonus + adjustment

  // Breakdown vắng (chỉ để hiển thị phiếu lương cho minh bạch)
  absentDaysP   Int @default(0) @map("absent_p")
  absentDaysKp  Int @default(0) @map("absent_kp")
  absentDaysMua Int @default(0) @map("absent_mua")
  absentDaysCho Int @default(0) @map("absent_cho")

  note String?

  createdAt DateTime @default(now()) @map("created_at")

  payroll WeeklyPayroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  worker  Worker        @relation(fields: [workerId], references: [id], onDelete: Restrict)

  @@unique([payrollId, workerId])
  @@index([workerId])
  @@map("weekly_payroll_lines")
}

// Sửa-sau-duyệt: tuần đã PAID không hủy được — điều chỉnh bù vào tuần sau.
model WeeklyPayrollAdjustment {
  id               String  @id @default(uuid()) @db.Uuid
  projectId        String  @map("project_id") @db.Uuid
  workerId         String  @map("worker_id") @db.Uuid
  appliedPayrollId String? @map("applied_payroll_id") @db.Uuid // null = chưa áp vào tuần nào

  amount      BigInt // âm/dương
  reason      String
  createdById String   @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  worker         Worker         @relation(fields: [workerId], references: [id], onDelete: Cascade)
  appliedPayroll WeeklyPayroll? @relation(fields: [appliedPayrollId], references: [id], onDelete: SetNull)
  createdBy      User           @relation("WeeklyPayrollAdjustmentCreatedBy", fields: [createdById], references: [id])

  @@index([projectId, workerId])
  @@index([appliedPayrollId])
  @@map("weekly_payroll_adjustments")
}

/// Singleton: 1 dòng duy nhất giữ số dư tiền tổng của công ty.
/// Mọi giao dịch thu/chi sẽ update currentBalance trong transaction.
model CompanyCash {
  id             String    @id @default(uuid()) @db.Uuid
  openingBalance Decimal   @default(0) @map("opening_balance") @db.Decimal(18, 2)
  openingDate    DateTime? @map("opening_date") @db.Date
  openingNote    String?   @map("opening_note") @db.Text
  openingSetBy   String?   @map("opening_set_by") @db.Uuid
  openingSetAt   DateTime? @map("opening_set_at")
  currentBalance Decimal   @default(0) @map("current_balance") @db.Decimal(18, 2)
  lastTxnAt      DateTime? @map("last_txn_at")
  initialized    Boolean   @default(false)
  updatedAt      DateTime  @updatedAt @map("updated_at")

  openingSetter User? @relation("CompanyCashOpeningSetter", fields: [openingSetBy], references: [id], onDelete: SetNull)

  @@map("company_cash")
}

/// Danh mục chi (admin quản lý). Vật tư / Máy móc / Văn phòng …
model ExpenseCategory {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  expenses         Expense[]
  cashTransactions CashTransaction[]

  @@index([active, sortOrder])
  @@map("expense_categories")
}

/// Lệnh chi do admin tạo trực tiếp, không qua workflow KS đề xuất.
/// pending → KT đánh dấu đã chi → paid (đồng thời tạo CashTransaction).
model Expense {
  id                 String          @id @default(uuid()) @db.Uuid
  code               String          @unique
  projectId          String?         @map("project_id") @db.Uuid
  categoryId         String          @map("category_id") @db.Uuid
  amount             Decimal         @db.Decimal(18, 2)
  payee              String?
  paymentMethod      String?         @map("payment_method")
  note               String?         @db.Text
  attachmentUrl      String?         @map("attachment_url")
  attachmentUrls     String[]        @default([]) @map("attachment_urls")
  status             ExpenseStatus   @default(pending)
  createdBy          String          @map("created_by") @db.Uuid
  createdAt          DateTime        @default(now()) @map("created_at")
  paidBy             String?         @map("paid_by") @db.Uuid
  paidAt             DateTime?       @map("paid_at")
  paidAmount         Decimal?        @map("paid_amount") @db.Decimal(18, 2)
  paidNote           String?         @map("paid_note") @db.Text
  paidReceiptUrl     String?         @map("paid_receipt_url")
  cancelledBy        String?         @map("cancelled_by") @db.Uuid
  cancelledAt        DateTime?       @map("cancelled_at")
  cancelledReason    String?         @map("cancelled_reason") @db.Text
  priority           ExpensePriority @default(normal)
  nextReminderAt     DateTime?       @map("next_reminder_at")
  payeeBankBin       String?         @map("payee_bank_bin") @db.VarChar(20)
  payeeAccountNumber String?         @map("payee_account_number") @db.VarChar(40)
  payeeAccountName   String?         @map("payee_account_name") @db.VarChar(200)
  payeeQrUrl         String?         @map("payee_qr_url")

  tptcApprovedBy     String?   @map("tptc_approved_by") @db.Uuid
  tptcApprovedAt     DateTime? @map("tptc_approved_at")
  tptcRejectedReason String?   @map("tptc_rejected_reason") @db.Text

  project      Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  category     ExpenseCategory @relation(fields: [categoryId], references: [id])
  creator      User            @relation("ExpenseCreator", fields: [createdBy], references: [id])
  payer        User?           @relation("ExpensePayer", fields: [paidBy], references: [id], onDelete: SetNull)
  canceller    User?           @relation("ExpenseCanceller", fields: [cancelledBy], references: [id], onDelete: SetNull)
  tptcApprover User?           @relation("ExpenseTptcApprover", fields: [tptcApprovedBy], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@index([projectId, createdAt(sort: Desc)])
  @@index([categoryId, createdAt(sort: Desc)])
  @@index([nextReminderAt])
  @@map("expenses")
}

/// Lệnh thu do admin tạo: thu từ khách / vay / hoàn ứng / khác.
/// pending → KT đánh dấu đã thu → received (đồng thời tạo CashTransaction direction=in).
model Receipt {
  id                 String        @id @default(uuid()) @db.Uuid
  code               String        @unique
  source             ReceiptSource
  projectId          String?       @map("project_id") @db.Uuid
  amount             Decimal       @db.Decimal(18, 2)
  payer              String?
  paymentMethod      String?       @map("payment_method")
  note               String?       @db.Text
  attachmentUrl      String?       @map("attachment_url")
  status             ReceiptStatus @default(pending)
  createdBy          String        @map("created_by") @db.Uuid
  createdAt          DateTime      @default(now()) @map("created_at")
  receivedBy         String?       @map("received_by") @db.Uuid
  receivedAt         DateTime?     @map("received_at")
  receivedAmount     Decimal?      @map("received_amount") @db.Decimal(18, 2)
  receivedNote       String?       @map("received_note") @db.Text
  receivedReceiptUrl String?       @map("received_receipt_url")
  cancelledBy        String?       @map("cancelled_by") @db.Uuid
  cancelledAt        DateTime?     @map("cancelled_at")
  cancelledReason    String?       @map("cancelled_reason") @db.Text

  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  creator   User     @relation("ReceiptCreator", fields: [createdBy], references: [id])
  receiver  User?    @relation("ReceiptReceiver", fields: [receivedBy], references: [id], onDelete: SetNull)
  canceller User?    @relation("ReceiptCanceller", fields: [cancelledBy], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@index([projectId, createdAt(sort: Desc)])
  @@index([source, createdAt(sort: Desc)])
  @@map("receipts")
}

/// Nhật ký mọi giao dịch thu/chi.
/// balanceAfter lưu sẵn để query nhanh + audit (không tính lại từ tổng).
model CashTransaction {
  id               String           @id @default(uuid()) @db.Uuid
  direction        CashTxnDirection
  amount           Decimal          @db.Decimal(18, 2)
  occurredAt       DateTime         @map("occurred_at")
  balanceAfter     Decimal          @map("balance_after") @db.Decimal(18, 2)
  refType          CashTxnRefType   @map("ref_type")
  refId            String?          @map("ref_id") @db.Uuid
  accountId        String           @map("account_id") @db.Uuid
  counterAccountId String?          @map("counter_account_id") @db.Uuid
  projectId        String?          @map("project_id") @db.Uuid
  categoryId       String?          @map("category_id") @db.Uuid
  note             String?          @db.Text
  createdBy        String           @map("created_by") @db.Uuid
  createdAt        DateTime         @default(now()) @map("created_at")

  project        Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  category       ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  creator        User             @relation("CashTransactionCreator", fields: [createdBy], references: [id])
  account        CashAccount      @relation("CashTransactionAccount", fields: [accountId], references: [id])
  counterAccount CashAccount?     @relation("CashTransactionCounterAccount", fields: [counterAccountId], references: [id], onDelete: SetNull)

  @@index([occurredAt(sort: Desc)])
  @@index([refType, refId])
  @@index([projectId, occurredAt])
  @@index([categoryId, occurredAt])
  @@index([createdAt(sort: Desc)])
  @@index([accountId, occurredAt(sort: Desc)])
  @@map("cash_transactions")
}
