model User {
  id                 String   @id @default(uuid()) @db.Uuid
  email              String   @unique
  passwordHash       String   @map("password_hash")
  fullName           String   @map("full_name")
  phone              String?
  role               UserRole
  isActive           Boolean  @default(true) @map("is_active")
  mustChangePassword Boolean  @default(true) @map("must_change_password")
  avatarUrl          String?  @map("avatar_url")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  managedProjects                  Project[]                     @relation("ProjectManager")
  engineeredProjects               Project[]                     @relation("MainEngineer")
  assignedEngineerFor              Task[]                        @relation("AssignedEngineer")
  assignedForemanFor               Task[]                        @relation("AssignedForeman")
  taskLogs                         TaskLog[]
  taskPhotos                       TaskPhoto[]
  qcItems                          QcItem[]
  qcProgressUpdates                QcProgress[]                  @relation("QcProgressUpdatedBy")
  qcPhotos                         QcPhoto[]
  qcLogs                           QcLog[]
  qcReviews                        QcReview[]
  taskQcLogs                       TaskQcLog[]                   @relation("TaskQcLogChecker")
  taskProgressHistories            TaskProgressHistory[]         @relation("TaskProgressUpdatedBy")
  taskQcResultsChecked             TaskQcResult[]                @relation("TaskQcResultCheckedBy")
  taskActivityLogs                 TaskActivityLog[]             @relation("TaskActivityActor")
  internalApprovedTasks            Task[]                        @relation("TaskInternalApprover")
  projectMembers                   ProjectMember[]
  addedProjectMembers              ProjectMember[]               @relation("ProjectMemberAddedBy")
  projectAssignments               ProjectMemberAssignment[]     @relation("ProjectAssignmentUser")
  projectAssignmentsAssigned       ProjectMemberAssignment[]     @relation("ProjectAssignmentAssigner")
  declaredSiteRestDays             SiteRestDay[]
  morningCheckins                  MorningCheckin[]              @relation("MorningCheckinUser")
  morningReports                   MorningReport[]
  eveningReports                   EveningReport[]
  technicalReportCreator           TaskTechnicalReport[]         @relation("TechReportCreator")
  technicalReportUpdater           TaskTechnicalReport[]         @relation("TechReportUpdater")
  materialReportCreator            TaskMaterialReport[]          @relation("MatReportCreator")
  materialReportUpdater            TaskMaterialReport[]          @relation("MatReportUpdater")
  laborReportCreator               TaskLaborReport[]             @relation("LaborReportCreator")
  laborReportUpdater               TaskLaborReport[]             @relation("LaborReportUpdater")
  equipmentReportCreator           TaskEquipmentReport[]         @relation("EquipReportCreator")
  equipmentReportUpdater           TaskEquipmentReport[]         @relation("EquipReportUpdater")
  technicalAttachmentsUploaded     TaskTechnicalAttachment[]
  reportPhotosUploaded             TaskReportPhoto[]
  kpiSnapshots                     KpiSnapshot[]
  engineerSalaryConfig             EngineerSalaryConfig?         @relation("EngineerSalary")
  engineerSalaryUpdated            EngineerSalaryConfig[]        @relation("EngineerSalaryUpdater")
  engineerSalaryHistory            EngineerSalaryHistory[]       @relation("EngineerSalaryChanger")
  engineerKpiMonthly               EngineerKpiMonthly[]          @relation("EngineerKpiMonthlyUser")
  engineerKpiMonthlyRated          EngineerKpiMonthly[]          @relation("EngineerKpiMonthlyRater")
  engineerKpiMonthlyFinalized      EngineerKpiMonthly[]          @relation("EngineerKpiMonthlyFinalizer")
  kpiSettingsChanged               KpiSettings[]                 @relation("KpiSettingsChanger")
  customerTaskRatings              CustomerTaskRating[]          @relation("KsRatedTask")
  customerKsRatings                CustomerKsRating[]            @relation("KsRatedDirectly")
  customerCommentsAuthored         CustomerComment[]             @relation("CustomerCommentAuthor")
  customerCommentReplies           CustomerCommentReply[]
  projectDrawingsUploaded          ProjectDrawing[]              @relation("ProjectDrawingUploader")
  projectDocumentsUploaded         ProjectDocument[]             @relation("ProjectDocumentUploader")
  projectDocumentAccessGranted     ProjectDocumentAccess[]       @relation("ProjectDocumentAccessGrantor")
  projectDocumentAccessUser        ProjectDocumentAccess[]       @relation("ProjectDocumentAccessUser")
  paymentSchedulesCreated          PaymentSchedule[]             @relation("PaymentScheduleCreator")
  projectChangeDraftsCreated       ProjectChangeDraft[]          @relation("ProjectChangeDraftCreator")
  projectChangeDraftsUpdated       ProjectChangeDraft[]          @relation("ProjectChangeDraftUpdater")
  projectDraftFilesUploaded        ProjectDraftFile[]            @relation("ProjectDraftFileUploader")
  projectAiAudits                  ProjectAiAudit[]              @relation("ProjectAiAuditActor")
  subcontractorsCreated            Subcontractor[]               @relation("SubcontractorCreator")
  subContractsCreated              SubContract[]                 @relation("SubContractCreator")
  subContractFiles                 SubContractFile[]
  subPaymentsRequested             SubPayment[]                  @relation("SubPaymentRequester")
  subPaymentsApproved              SubPayment[]                  @relation("SubPaymentApprover")
  subPaymentsPaid                  SubPayment[]                  @relation("SubPaymentPayer")
  subEvaluations                   SubEvaluation[]
  createdProjectPhases             ProjectPhase[]
  createdQcChecklistTemplates      QcChecklistTemplate[]
  assignedTptcAssignments          TptcAssignment[]              @relation("TptcAssignmentAssignee")
  createdTptcAssignments           TptcAssignment[]              @relation("TptcAssignmentAssigner")
  tptcDailyStatuses                TptcAssignmentDailyStatus[]
  taskDailyAssignments             TaskDailyAssignment[]
  dailyReportSubmissions           DailyReportSubmission[]
  designPhotoGroupsCreated         DesignPhotoGroup[]            @relation("DesignPhotoGroupCreator")
  designPhotoGroupAccess           DesignPhotoGroupAccess[]      @relation("DesignPhotoGroupAccessUser")
  designPhotoGroupAccessGranted    DesignPhotoGroupAccess[]      @relation("DesignPhotoGroupAccessGrantor")
  designPhotosUploaded             DesignPhoto[]                 @relation("DesignPhotoUploader")
  staffNotifications               StaffNotification[]           @relation("StaffNotificationRecipient")
  staffNotificationsActed          StaffNotification[]           @relation("StaffNotificationActor")
  customerNotificationsActed       CustomerNotification[]        @relation("CustomerNotificationActor")
  pushSubscriptions                PushSubscription[]
  pushSendLogs                     PushSendLog[]
  projectActivityLogs              ProjectActivityLog[]          @relation("ProjectActivityActor")
  ksAttendances                    KsAttendance[]                @relation("KsAttendanceUser")
  shiftAssignments                 UserShiftAssignment[]         @relation("UserShiftAssignmentUser")
  workersCreated                   Worker[]                      @relation("WorkerCreatedBy")
  workerAttendancesMarked          WorkerAttendance[]            @relation("WorkerAttendanceMarkedBy")
  workOrdersCreated                WorkOrder[]                   @relation("WorkOrderCreatedBy")
  workerTimesheetsCreated          WorkerTimesheet[]             @relation("WorkerTimesheetCreatedBy")
  workOrderOutputsCreated          WorkOrderOutput[]             @relation("WorkOrderOutputCreatedBy")
  workOrderOutputsApproved         WorkOrderOutput[]             @relation("WorkOrderOutputApprovedBy")
  workOrderOutputPhotosUploaded    WorkOrderOutputPhoto[]        @relation("WorkOrderOutputPhotoUploadedBy")
  workOrderOutputQcChecksDone      WorkOrderOutputQcCheck[]      @relation("WorkOrderOutputQcCheckCheckedBy")
  workerQcIssuesCreated            WorkerQcIssue[]               @relation("WorkerQcIssueCreatedBy")
  weeklyPayrollsClosed             WeeklyPayroll[]               @relation("WeeklyPayrollClosedBy")
  weeklyPayrollsReadied            WeeklyPayroll[]               @relation("WeeklyPayrollReadiedBy")
  weeklyPayrollsPaid               WeeklyPayroll[]               @relation("WeeklyPayrollPaidBy")
  weeklyPayrollAdjustmentsCreated  WeeklyPayrollAdjustment[]     @relation("WeeklyPayrollAdjustmentCreatedBy")
  gradeRatesCreated                GradeRate[]                   @relation("GradeRateCreatedBy")
  gradeHistoryProposed             GradeHistory[]                @relation("GradeHistoryProposer")
  gradeHistoryApproved             GradeHistory[]                @relation("GradeHistoryApprover")
  workerDocsUploaded               WorkerDoc[]                   @relation("WorkerDocUploader")
  materialProposalsCreated         MaterialProposal[]            @relation("MatProposalKs")
  materialProposalsProcessed       MaterialProposal[]            @relation("MatProposalProcessor")
  materialProposalsClosed          MaterialProposal[]            @relation("MatProposalCloser")
  materialProposalCommentsAuthored MaterialProposalComment[]     @relation("MatProposalCommentAuthor")
  materialReceiptsLogged           MaterialProposalItemReceipt[] @relation("MatProposalItemReceiptReceiver")
  materialDebtsRecorded            MaterialProposalItemDebt[]    @relation("MatProposalItemDebtRecorder")
  supplierPayOrdersCreated         SupplierPaymentOrder[]        @relation("SupplierPayOrderCreator")
  supplierPayOrdersApproved        SupplierPaymentOrder[]        @relation("SupplierPayOrderApprover")
  supplierPayOrdersRejected        SupplierPaymentOrder[]        @relation("SupplierPayOrderRejecter")
  supplierPayOrdersPaid            SupplierPaymentOrder[]        @relation("SupplierPayOrderPayer")
  suppliersCreated                 Supplier[]                    @relation("SupplierCreator")
  supplierPricesUpdated            SupplierMaterialPrice[]       @relation("SupplierMaterialPriceUpdater")
  projectBudgetsCreated            ProjectBudget[]               @relation("ProjectBudgetCreator")
  projectBudgetsLocked             ProjectBudget[]               @relation("ProjectBudgetLocker")
  projectBudgetAmendmentsProposed  ProjectBudgetAmendment[]      @relation("ProjectBudgetAmendmentProposer")
  projectBudgetAmendmentsApproved  ProjectBudgetAmendment[]      @relation("ProjectBudgetAmendmentApprover")
  companyCashOpeningSet            CompanyCash[]                 @relation("CompanyCashOpeningSetter")
  expensesCreated                  Expense[]                     @relation("ExpenseCreator")
  expensesPaid                     Expense[]                     @relation("ExpensePayer")
  expensesCancelled                Expense[]                     @relation("ExpenseCanceller")
  expensesTptcApproved             Expense[]                     @relation("ExpenseTptcApprover")
  receiptsCreated                  Receipt[]                     @relation("ReceiptCreator")
  receiptsReceived                 Receipt[]                     @relation("ReceiptReceiver")
  receiptsCancelled                Receipt[]                     @relation("ReceiptCanceller")
  cashTransactionsCreated          CashTransaction[]             @relation("CashTransactionCreator")

  @@map("users")
}

model CashAccount {
  id             String          @id @default(uuid()) @db.Uuid
  code           String          @unique
  name           String
  kind           CashAccountKind
  openingBalance Decimal         @default(0) @map("opening_balance") @db.Decimal(18, 2)
  currentBalance Decimal         @default(0) @map("current_balance") @db.Decimal(18, 2)
  sortOrder      Int             @default(0) @map("sort_order")
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  cashTransactions        CashTransaction[]      @relation("CashTransactionAccount")
  cashTransactionsCounter CashTransaction[]      @relation("CashTransactionCounterAccount")
  supplierPayOrders       SupplierPaymentOrder[] @relation("SupplierPayOrderAccount")

  @@index([active, sortOrder])
  @@map("cash_accounts")
}

model KsAttendance {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  workDate          DateTime  @map("work_date") @db.Date
  checkInAt         DateTime  @map("check_in_at")
  checkInLat        Decimal?  @map("check_in_lat") @db.Decimal(10, 7)
  checkInLng        Decimal?  @map("check_in_lng") @db.Decimal(10, 7)
  checkInAccuracy   Decimal?  @map("check_in_accuracy") @db.Decimal(10, 2)
  checkInPhotoKey   String?   @map("check_in_photo_key")
  checkInAddress    String?   @map("check_in_address") @db.Text
  checkOutAt        DateTime? @map("check_out_at")
  checkOutLat       Decimal?  @map("check_out_lat") @db.Decimal(10, 7)
  checkOutLng       Decimal?  @map("check_out_lng") @db.Decimal(10, 7)
  checkOutAccuracy  Decimal?  @map("check_out_accuracy") @db.Decimal(10, 2)
  checkOutPhotoKey  String?   @map("check_out_photo_key")
  checkOutAddress   String?   @map("check_out_address") @db.Text
  durationMinutes   Int?      @map("duration_minutes")
  lateMinutes       Int?      @map("late_minutes")
  earlyLeaveMinutes Int?      @map("early_leave_minutes")
  shiftIdAtCheckIn  String?   @map("shift_id_at_check_in") @db.Uuid
  shiftIdAtCheckOut String?   @map("shift_id_at_check_out") @db.Uuid
  note              String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user User @relation("KsAttendanceUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, workDate])
  @@map("ks_attendance")
}

model KsGeoErrorLog {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  kind            String   @db.VarChar(20)
  action          String?  @db.VarChar(10)
  permissionState String?  @map("permission_state") @db.VarChar(20)
  errorMessage    String?  @map("error_message") @db.Text
  userAgent       String?  @map("user_agent") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("ks_geo_error_log")
}

model Shift {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique
  startTime    String   @map("start_time")
  endTime      String   @map("end_time")
  graceMinutes Int      @default(5) @map("grace_minutes")
  isActive     Boolean  @default(true) @map("is_active")
  note         String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  assignments UserShiftAssignment[] @relation("ShiftAssignmentShift")

  @@map("shifts")
}

model UserShiftAssignment {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  shiftId    String   @map("shift_id") @db.Uuid
  daysOfWeek Int[]    @map("days_of_week")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user  User  @relation("UserShiftAssignmentUser", fields: [userId], references: [id], onDelete: Cascade)
  shift Shift @relation("ShiftAssignmentShift", fields: [shiftId], references: [id], onDelete: Cascade)

  @@unique([userId, shiftId])
  @@index([userId])
  @@map("user_shift_assignments")
}

model Project {
  id                     String           @id @default(uuid()) @db.Uuid
  code                   String           @unique
  name                   String
  customerName           String           @map("customer_name")
  customerPhone          String           @map("customer_phone")
  customerIdNumber       String?          @map("customer_id_number")
  address                String
  areaM2                 Decimal          @map("area_m2") @db.Decimal(12, 2)
  unitPrice              Decimal          @map("unit_price") @db.Decimal(15, 2)
  contractValue          Decimal?         @map("contract_value") @db.Decimal(15, 2)
  profitMarginPct        Decimal?         @map("profit_margin_pct") @db.Decimal(5, 2)
  startDate              DateTime         @map("start_date") @db.Date
  expectedEndDate        DateTime         @map("expected_end_date") @db.Date
  plannedDeadline        DateTime?        @map("planned_deadline") @db.Date
  actualEndDate          DateTime?        @map("actual_end_date") @db.Date
  goLiveDate             DateTime?        @map("go_live_date") @db.Date
  customerPortalToken    String?          @unique @map("customer_portal_token") @db.Uuid
  customerPortalEnabled  Boolean          @default(true) @map("customer_portal_enabled")
  customerPortalPassword String?          @map("customer_portal_password")
  projectManagerId       String           @map("project_manager_id") @db.Uuid
  mainEngineerId         String           @map("main_engineer_id") @db.Uuid
  status                 ProjectStatus    @default(planning)
  laborMode              ProjectLaborMode @default(self) @map("labor_mode")
  notes                  String?
  contractMeta           Json?            @map("contract_meta")
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")

  projectManager            User                       @relation("ProjectManager", fields: [projectManagerId], references: [id])
  mainEngineer              User                       @relation("MainEngineer", fields: [mainEngineerId], references: [id])
  tasks                     Task[]
  phases                    ProjectPhase[]
  paymentSchedules          PaymentSchedule[]
  drawings                  ProjectDrawing[]
  customerExportJobs        CustomerExportJob[]
  changeDrafts              ProjectChangeDraft[]
  projectMembers            ProjectMember[]
  memberAssignments         ProjectMemberAssignment[]
  siteRestDays              SiteRestDay[]
  morningCheckins           MorningCheckin[]
  morningReports            MorningReport[]
  eveningReports            EveningReport[]
  kpiSnapshots              KpiSnapshot[]
  customerComments          CustomerComment[]
  customerAcknowledgments   CustomerAcknowledgment[]
  customerTaskRatings       CustomerTaskRating[]
  customerKsRatings         CustomerKsRating[]
  customerSessions          CustomerSession[]
  customerLoginAttempts     CustomerLoginAttempt[]
  subContracts              SubContract[]
  tptcAssignments           TptcAssignment[]
  documents                 ProjectDocument[]
  aiAnalysisCaches          ProjectAiAnalysisCache[]
  designPhotoGroups         DesignPhotoGroup[]
  staffNotifications        StaffNotification[]
  customerNotifications     CustomerNotification[]
  activityLogs              ProjectActivityLog[]
  customerPushSubscriptions CustomerPushSubscription[]
  workers                   Worker[]
  workerAttendances         WorkerAttendance[]
  taskDailyAssignments      TaskDailyAssignment[]
  materialProposals         MaterialProposal[]
  designContract            DesignContract?
  projectBudget             ProjectBudget?
  projectComponents         ProjectComponent[]
  workOrders                WorkOrder[]
  workerTimesheets          WorkerTimesheet[]
  workOrderOutputs          WorkOrderOutput[]
  workerQcIssues            WorkerQcIssue[]
  weeklyPayrolls            WeeklyPayroll[]
  weeklyPayrollAdjustments  WeeklyPayrollAdjustment[]
  expenses                  Expense[]
  receipts                  Receipt[]
  cashTransactions          CashTransaction[]

  @@index([status])
  @@map("projects")
}

model ProjectPhase {
  id               String      @id @default(uuid()) @db.Uuid
  projectId        String      @map("project_id") @db.Uuid
  code             String
  name             String
  description      String?     @db.Text
  displayOrder     Int         @map("display_order")
  duration         Int
  plannedStartDate DateTime    @map("planned_start_date") @db.Date
  plannedEndDate   DateTime    @map("planned_end_date") @db.Date
  actualStartDate  DateTime?   @map("actual_start_date") @db.Date
  actualEndDate    DateTime?   @map("actual_end_date") @db.Date
  status           PhaseStatus @default(not_started)
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  createdBy        String      @map("created_by") @db.Uuid

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User    @relation(fields: [createdBy], references: [id])
  tasks   Task[]  @relation("TaskProjectPhase")

  @@unique([projectId, displayOrder])
  @@index([projectId])
  @@map("project_phases")
}

model TaskTemplate {
  id                  String       @id @default(uuid()) @db.Uuid
  code                String
  phase               TaskPhase
  phaseCode           String       @map("phase_code")
  phaseName           String       @map("phase_name")
  phaseDuration       Int          @map("phase_duration")
  phaseOrder          Int          @map("phase_order")
  name                String
  defaultOffsetDays   Int          @map("default_offset_days")
  defaultDurationDays Int          @map("default_duration_days")
  duration            Int          @default(1)
  defaultTeam         String       @map("default_team")
  defaultInspector    String       @map("default_inspector")
  materialsNeeded     String       @map("materials_needed") @db.Text
  proposerRole        String       @map("proposer_role")
  ordererRole         String       @map("orderer_role")
  receiverRole        String       @map("receiver_role")
  qcChecklist         String       @map("qc_checklist") @db.Text
  category            TaskCategory @default(normal)
  isMilestone         Boolean      @default(false) @map("is_milestone")
  displayOrder        Int          @map("display_order")
  templateCategory    String       @map("template_category")
  isActive            Boolean      @default(true) @map("is_active")
  createdAt           DateTime     @default(now()) @map("created_at")

  // Mapping sang StandardTaskCatalog mới (Phase 3 sẽ fill dần qua UI)
  stdPhaseCode String?              @map("std_phase_code")
  stdTaskCode  String?              @map("std_task_code")
  stdCatalogId String?              @map("std_catalog_id") @db.Uuid
  stdCatalog   StandardTaskCatalog? @relation("TemplateStdCatalog", fields: [stdCatalogId], references: [id], onDelete: SetNull)

  tasks           Task[]
  qcTemplate      QcChecklistTemplate?
  assignmentItems TaskAssignmentTemplateItem[]

  @@map("task_templates")
}

/// Catalog mã chuẩn `GĐ-CT` cho danh mục công tác nhà phố Huỳnh Gia.
/// Single source of truth. Tham chiếu: tài liệu nền `/SOP/danh-muc-cong-tac.html`.
/// Luật giữ mã: số đã cấp là vĩnh viễn → soft-retire qua `retiredAt`, không xoá.
model StandardTaskCatalog {
  id           String    @id @default(uuid()) @db.Uuid
  phaseCode    String    @map("phase_code") // "01"..."09"
  taskCode     String    @map("task_code") // "010","020"... bước 10
  phaseName    String    @map("phase_name") // "Chuẩn bị & khởi công"
  taskName     String    @map("task_name")
  groupLabel   String?   @map("group_label") // "Phần âm (trước tô)" cho GĐ 07
  note         String?   @db.Text // ghi chú in nghiêng
  isHoldPoint  Boolean   @default(false) @map("is_hold_point")
  displayOrder Int       @map("display_order") // thứ tự hiển thị; mã = danh tính, KHÔNG phải thứ tự
  retiredAt    DateTime? @map("retired_at") // soft-delete, không xoá để giữ luật mã vĩnh viễn

  // Default values cho khi tạo Task mới — TPTC fill dần qua UI admin (catalog "ready dần")
  defaultTeam         String?      @map("default_team")
  defaultInspector    String?      @map("default_inspector")
  defaultOffsetDays   Int?         @map("default_offset_days")
  defaultDurationDays Int?         @map("default_duration_days")
  materialsNeeded     String?      @map("materials_needed") @db.Text
  qcChecklist         String?      @map("qc_checklist") @db.Text
  proposerRole        String?      @map("proposer_role")
  ordererRole         String?      @map("orderer_role")
  receiverRole        String?      @map("receiver_role")
  category            TaskCategory @default(normal)
  isMilestone         Boolean      @default(false) @map("is_milestone")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  templates   TaskTemplate[]      @relation("TemplateStdCatalog")
  tasks       Task[]              @relation("TaskStdCatalog")
  budgetItems ProjectBudgetItem[]

  @@unique([phaseCode, taskCode])
  @@index([phaseCode, displayOrder])
  @@index([retiredAt])
  @@map("standard_task_catalog")
}

