generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  engineer
  foreman
  accountant
  construction_manager
}

enum SubcontractorType {
  individual
  company
}

enum SubcontractorStatus {
  active
  inactive
  blacklisted
}

enum SubContractStatus {
  draft
  active
  completed
  cancelled
}

enum SubContractUnit {
  lump_sum
  per_m2
  per_day
  per_unit
}

enum SubPaymentStatus {
  pending
  requested
  approved
  paid
  cancelled
}

enum ProjectStatus {
  planning
  in_progress
  completed
  paused
}

enum TaskPhase {
  P1_CHUAN_BI
  P2_MONG
  P3_KHUNG_TRET
  P4_KHUNG_LAU
  P5_ME_XAY_TO
  P6_OP_LAT
  P7_SON_BA
  P8_LAP_TB
  P9_BAN_GIAO
}

enum TaskStatus {
  not_started
  in_progress
  done
  inspected
  delayed
  na
}

enum TaskLogType {
  status_change
  note
  photo_uploaded
  assignment_change
  report_edit
  reminder_sent
}

enum PaymentStatus {
  not_collected
  request_sent
  collected
  customer_late
}

enum PhaseStatus {
  not_started
  in_progress
  completed
}

enum CustomerPortalCommentType {
  comment
  reply
}

enum ProjectMemberRole {
  engineer
  foreman
  accountant
  construction_manager
}

enum ProjectRoleType {
  pm_construction_manager
  pm_engineer
  pm_material_manager
  pm_labor_manager
  pm_accountant
}

enum TechnicalAttachmentType {
  drawing
  spec_doc
  reference
}

enum TechnicalReportStatus {
  working
  paused
  completed
}

enum ReportPhotoType {
  technical
  material
  labor
  equipment
}

enum PauseReason {
  RAIN
  LACK_MATERIAL
  WAIT_INSPECTION
  WAIT_SUBCONTRACTOR
  WAIT_CUSTOMER
  OTHER
}

enum ReportDecision {
  WORK
  PAUSE
}

enum DailyRating {
  MET
  UNDER
  OVER
}

enum SiteRestReason {
  SUNDAY
  HOLIDAY
  STORM
  OTHER
}

enum KpiSnapshotType {
  DAILY
  MONTHLY_FINAL
}

enum KpiMonthlyStatus {
  draft
  pending
  finalized
}

enum QcItemStatus {
  unchecked
  passed
  failed
}

enum QcLogAction {
  status_changed
  photo_added
  note_updated
  item_added
}

enum QcReviewAction {
  approved
  rejected
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  phone        String?
  role               UserRole
  isActive           Boolean  @default(true) @map("is_active")
  mustChangePassword Boolean  @default(true) @map("must_change_password")
  avatarUrl          String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  managedProjects     Project[]       @relation("ProjectManager")
  engineeredProjects  Project[]       @relation("MainEngineer")
  assignedEngineerFor Task[]          @relation("AssignedEngineer")
  assignedForemanFor  Task[]          @relation("AssignedForeman")
  taskLogs            TaskLog[]
  taskPhotos          TaskPhoto[]
  qcItems             QcItem[]
  qcProgressUpdates   QcProgress[]        @relation("QcProgressUpdatedBy")
  qcPhotos            QcPhoto[]
  qcLogs              QcLog[]
  qcReviews           QcReview[]
  taskQcLogs          TaskQcLog[] @relation("TaskQcLogChecker")
  projectMembers      ProjectMember[]
  addedProjectMembers ProjectMember[] @relation("ProjectMemberAddedBy")
  projectAssignments          ProjectMemberAssignment[] @relation("ProjectAssignmentUser")
  projectAssignmentsAssigned  ProjectMemberAssignment[] @relation("ProjectAssignmentAssigner")
  declaredSiteRestDays SiteRestDay[]
  morningReports      MorningReport[]
  eveningReports      EveningReport[]
  technicalReportCreator TaskTechnicalReport[] @relation("TechReportCreator")
  technicalReportUpdater TaskTechnicalReport[] @relation("TechReportUpdater")
  materialReportCreator TaskMaterialReport[] @relation("MatReportCreator")
  materialReportUpdater TaskMaterialReport[] @relation("MatReportUpdater")
  laborReportCreator TaskLaborReport[] @relation("LaborReportCreator")
  laborReportUpdater TaskLaborReport[] @relation("LaborReportUpdater")
  equipmentReportCreator TaskEquipmentReport[] @relation("EquipReportCreator")
  equipmentReportUpdater TaskEquipmentReport[] @relation("EquipReportUpdater")
  technicalAttachmentsUploaded TaskTechnicalAttachment[]
  reportPhotosUploaded TaskReportPhoto[]
  kpiSnapshots        KpiSnapshot[]
  engineerSalaryConfig       EngineerSalaryConfig?  @relation("EngineerSalary")
  engineerSalaryUpdated      EngineerSalaryConfig[] @relation("EngineerSalaryUpdater")
  engineerSalaryHistory      EngineerSalaryHistory[] @relation("EngineerSalaryChanger")
  engineerKpiMonthly         EngineerKpiMonthly[]   @relation("EngineerKpiMonthlyUser")
  engineerKpiMonthlyRated    EngineerKpiMonthly[]   @relation("EngineerKpiMonthlyRater")
  engineerKpiMonthlyFinalized EngineerKpiMonthly[]  @relation("EngineerKpiMonthlyFinalizer")
  customerCommentReplies CustomerCommentReply[]
  subcontractorsCreated Subcontractor[] @relation("SubcontractorCreator")
  subContractsCreated   SubContract[]   @relation("SubContractCreator")
  subContractFiles      SubContractFile[]
  subPaymentsRequested  SubPayment[]    @relation("SubPaymentRequester")
  subPaymentsApproved   SubPayment[]    @relation("SubPaymentApprover")
  subPaymentsPaid       SubPayment[]    @relation("SubPaymentPayer")
  subEvaluations        SubEvaluation[]
  createdProjectPhases  ProjectPhase[]

  @@map("users")
}

model Project {
  id                     String        @id @default(uuid()) @db.Uuid
  code                   String        @unique
  name                   String
  customerName           String        @map("customer_name")
  customerPhone          String        @map("customer_phone")
  customerIdNumber       String?       @map("customer_id_number")
  address                String
  areaM2                 Decimal       @map("area_m2") @db.Decimal(12, 2)
  unitPrice              Decimal       @map("unit_price") @db.Decimal(15, 2)
  contractValue          Decimal?      @map("contract_value") @db.Decimal(15, 2)
  startDate              DateTime      @map("start_date") @db.Date
  expectedEndDate        DateTime      @map("expected_end_date") @db.Date
  plannedDeadline        DateTime?     @map("planned_deadline") @db.Date
  actualEndDate          DateTime?     @map("actual_end_date") @db.Date
  goLiveDate             DateTime?     @map("go_live_date") @db.Date
  customerPortalToken    String?       @unique @map("customer_portal_token") @db.Uuid
  customerPortalEnabled  Boolean       @default(true) @map("customer_portal_enabled")
  customerPortalPassword String?       @map("customer_portal_password")
  projectManagerId       String        @map("project_manager_id") @db.Uuid
  mainEngineerId         String        @map("main_engineer_id") @db.Uuid
  status                 ProjectStatus @default(planning)
  notes                  String?
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  projectManager          User                     @relation("ProjectManager", fields: [projectManagerId], references: [id])
  mainEngineer            User                     @relation("MainEngineer", fields: [mainEngineerId], references: [id])
  tasks                   Task[]
  phases                  ProjectPhase[]
  paymentSchedules        PaymentSchedule[]
  projectMembers          ProjectMember[]
  memberAssignments       ProjectMemberAssignment[]
  siteRestDays            SiteRestDay[]
  morningReports          MorningReport[]
  eveningReports          EveningReport[]
  kpiSnapshots            KpiSnapshot[]
  customerComments        CustomerComment[]
  customerAcknowledgments CustomerAcknowledgment[]
  customerSessions        CustomerSession[]
  customerLoginAttempts   CustomerLoginAttempt[]
  subContracts            SubContract[]

  @@index([status])
  @@map("projects")
}

model ProjectPhase {
  id               String      @id @default(uuid()) @db.Uuid
  projectId        String      @map("project_id") @db.Uuid
  code             String
  name             String
  description      String?     @db.Text
  displayOrder     Int         @map("display_order")
  duration         Int
  plannedStartDate DateTime    @map("planned_start_date") @db.Date
  plannedEndDate   DateTime    @map("planned_end_date") @db.Date
  actualStartDate  DateTime?   @map("actual_start_date") @db.Date
  actualEndDate    DateTime?   @map("actual_end_date") @db.Date
  status           PhaseStatus @default(not_started)
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")
  createdBy        String      @map("created_by") @db.Uuid

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User    @relation(fields: [createdBy], references: [id])
  tasks   Task[]  @relation("TaskProjectPhase")

  @@unique([projectId, displayOrder])
  @@index([projectId])
  @@map("project_phases")
}

model TaskTemplate {
  id                  String    @id @default(uuid()) @db.Uuid
  code                String
  phase               TaskPhase
  phaseCode           String    @map("phase_code")
  phaseName           String    @map("phase_name")
  phaseDuration       Int       @map("phase_duration")
  phaseOrder          Int       @map("phase_order")
  name                String
  defaultOffsetDays   Int       @map("default_offset_days")
  defaultDurationDays Int       @map("default_duration_days")
  defaultTeam         String    @map("default_team")
  defaultInspector    String    @map("default_inspector")
  materialsNeeded     String    @map("materials_needed") @db.Text
  proposerRole        String    @map("proposer_role")
  ordererRole         String    @map("orderer_role")
  receiverRole        String    @map("receiver_role")
  qcChecklist         String    @map("qc_checklist") @db.Text
  isMilestone         Boolean   @default(false) @map("is_milestone")
  displayOrder        Int       @map("display_order")
  templateCategory    String    @map("template_category")
  isActive            Boolean   @default(true) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at")

  tasks Task[]

  @@map("task_templates")
}

model Task {
  id                 String     @id @default(uuid()) @db.Uuid
  projectId          String     @map("project_id") @db.Uuid
  templateId         String?    @map("template_id") @db.Uuid
  phaseId            String?    @map("phase_id") @db.Uuid
  code               String
  phase              TaskPhase
  name               String
  offsetDays         Int        @map("offset_days")
  durationDays       Int        @map("duration_days")
  duration           Int        @default(1)
  plannedStartDate   DateTime   @map("planned_start_date") @db.Date
  plannedEndDate     DateTime   @map("planned_end_date") @db.Date
  actualStartDate    DateTime?  @map("actual_start_date") @db.Date
  actualEndDate      DateTime?  @map("actual_end_date") @db.Date
  assignedEngineerId String?    @map("assigned_engineer_id") @db.Uuid
  assignedForemanId  String?    @map("assigned_foreman_id") @db.Uuid
  team               String?    @map("team")
  inspectorName      String     @map("inspector_name")
  materialsNeeded    String     @map("materials_needed") @db.Text
  proposerRole       String     @map("proposer_role")
  ordererRole        String     @map("orderer_role")
  receiverRole       String     @map("receiver_role")
  qcChecklist        String     @map("qc_checklist") @db.Text
  isMilestone        Boolean    @default(false) @map("is_milestone")
  visibleToCustomer  Boolean    @default(false) @map("visible_to_customer")
  status             TaskStatus @default(not_started)
  isActive           Boolean    @default(true) @map("is_active")
  displayOrder       Int?       @map("display_order")
  notes              String?    @db.Text
  qcProgress         Json?      @map("qc_progress")
  technicalRequirements String? @map("technical_requirements") @db.Text
  constructionMethod String?    @map("construction_method") @db.Text
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  project               Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template              TaskTemplate?            @relation(fields: [templateId], references: [id])
  projectPhase          ProjectPhase?            @relation("TaskProjectPhase", fields: [phaseId], references: [id], onDelete: SetNull)
  assignedEngineer      User?                    @relation("AssignedEngineer", fields: [assignedEngineerId], references: [id], onDelete: SetNull)
  assignedForeman       User?                    @relation("AssignedForeman", fields: [assignedForemanId], references: [id], onDelete: SetNull)
  taskLogs              TaskLog[]
  taskPhotos            TaskPhoto[]
  qcItems               QcItem[]
  materialItems         TaskMaterialItem[]
  qcProgressItems       QcProgress[]
  qcPhotos              QcPhoto[]
  qcLogs                QcLog[]
  qcReviews             QcReview[]
  taskQcLogs            TaskQcLog[]
  morningReportTasks    MorningReportTask[]
  eveningReportTasks    EveningReportTask[]
  technicalReports      TaskTechnicalReport[]
  materialReports       TaskMaterialReport[]
  laborReports          TaskLaborReport[]
  equipmentReports      TaskEquipmentReport[]
  technicalAttachments  TaskTechnicalAttachment[]
  reportPhotos          TaskReportPhoto[]
  customerComments      CustomerComment[]
  customerAcknowledgments CustomerAcknowledgment[]
  subContractTasks      SubContractTask[]
  subPayments           SubPayment[]

  @@unique([projectId, code])
  @@index([projectId, isActive, displayOrder, code])
  @@index([projectId, phaseId, isActive])
  @@index([status])
  @@index([projectId, visibleToCustomer])
  @@map("tasks")
}

model TaskMaterialItem {
  id          String   @id @default(uuid()) @db.Uuid
  taskId      String   @map("task_id") @db.Uuid
  name        String
  isAvailable Boolean  @default(false) @map("is_available")
  orderIndex  Int      @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, orderIndex])
  @@map("task_material_items")
}

model TaskLog {
  id        String      @id @default(uuid()) @db.Uuid
  taskId    String      @map("task_id") @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  logType   TaskLogType @map("log_type")
  oldValue  String?     @map("old_value")
  newValue  String?     @map("new_value")
  content   String      @db.Text
  createdAt DateTime    @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([taskId, createdAt])
  @@map("task_logs")
}

model TaskPhoto {
  id                  String     @id @default(uuid()) @db.Uuid
  taskId              String     @map("task_id") @db.Uuid
  uploadedBy          String     @map("uploaded_by") @db.Uuid
  photoUrl            String     @map("photo_url")
  thumbnailUrl        String     @map("thumbnail_url")
  caption             String?
  fileSizeKb          Int        @map("file_size_kb")
  takenAt             DateTime?  @map("taken_at")
  eveningReportTaskId String?    @map("evening_report_task_id") @db.Uuid
  createdAt           DateTime   @default(now()) @map("created_at")

  task              Task               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user              User               @relation(fields: [uploadedBy], references: [id])
  eveningReportTask EveningReportTask? @relation(fields: [eveningReportTaskId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
  @@index([eveningReportTaskId])
  @@map("task_photos")
}

model QcItem {
  id             String   @id @default(uuid()) @db.Uuid
  taskId         String   @map("task_id") @db.Uuid
  templateItemId String?  @map("template_item_id") @db.Uuid
  content        String   @db.Text
  requirePhoto   Boolean  @default(false) @map("require_photo")
  requireNote    Boolean  @default(false) @map("require_note")
  createdBy      String   @map("created_by") @db.Uuid
  orderIndex     Int      @map("order_index")
  createdAt      DateTime @default(now()) @map("created_at")

  task      Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  creator   User         @relation(fields: [createdBy], references: [id])
  progress  QcProgress?
  photos    QcPhoto[]
  logs      QcLog[]
  taskQcLogs TaskQcLog[]

  @@index([taskId, orderIndex])
  @@map("qc_items")
}

model QcProgress {
  id            String       @id @default(uuid()) @db.Uuid
  qcItemId      String       @unique @map("qc_item_id") @db.Uuid
  taskId        String       @map("task_id") @db.Uuid
  status        QcItemStatus @default(unchecked)
  note          String?      @db.Text
  noPhotoReason Boolean      @default(false) @map("no_photo_reason")
  updatedBy     String       @map("updated_by") @db.Uuid
  updatedAt     DateTime     @default(now()) @map("updated_at")

  item    QcItem @relation(fields: [qcItemId], references: [id], onDelete: Cascade)
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  updater User   @relation("QcProgressUpdatedBy", fields: [updatedBy], references: [id])

  @@index([taskId, status])
  @@map("qc_progress")
}

model QcPhoto {
  id         String   @id @default(uuid()) @db.Uuid
  qcItemId   String   @map("qc_item_id") @db.Uuid
  taskId     String   @map("task_id") @db.Uuid
  url        String
  uploadedBy String   @map("uploaded_by") @db.Uuid
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  item     QcItem @relation(fields: [qcItemId], references: [id], onDelete: Cascade)
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploader User   @relation(fields: [uploadedBy], references: [id])

  @@index([taskId, uploadedAt])
  @@index([qcItemId])
  @@map("qc_photos")
}

model QcLog {
  id          String       @id @default(uuid()) @db.Uuid
  taskId      String       @map("task_id") @db.Uuid
  qcItemId    String?      @map("qc_item_id") @db.Uuid
  action      QcLogAction
  fromStatus  QcItemStatus? @map("from_status")
  toStatus    QcItemStatus? @map("to_status")
  note        String?      @db.Text
  performedBy String       @map("performed_by") @db.Uuid
  performedAt DateTime     @default(now()) @map("performed_at")

  task      Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  item      QcItem? @relation(fields: [qcItemId], references: [id], onDelete: SetNull)
  performer User    @relation(fields: [performedBy], references: [id])

  @@index([taskId, performedAt])
  @@index([qcItemId])
  @@map("qc_logs")
}

model TaskQcLog {
  id              String   @id @default(uuid()) @db.Uuid
  taskId          String   @map("task_id") @db.Uuid
  qcItemId        String   @map("qc_item_id") @db.Uuid
  eveningReportId String?  @map("evening_report_id") @db.Uuid
  checkedAt       DateTime @default(now()) @map("checked_at")
  checkedBy       String   @map("checked_by") @db.Uuid
  photos          String[]
  note            String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  task          Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  qcItem        QcItem        @relation(fields: [qcItemId], references: [id], onDelete: Cascade)
  eveningReport EveningReport? @relation(fields: [eveningReportId], references: [id], onDelete: SetNull)
  checker       User          @relation("TaskQcLogChecker", fields: [checkedBy], references: [id])

  @@index([taskId])
  @@index([qcItemId])
  @@index([eveningReportId])
  @@map("task_qc_logs")
}

model QcReview {
  id         String         @id @default(uuid()) @db.Uuid
  taskId      String        @map("task_id") @db.Uuid
  action      QcReviewAction
  reviewerId  String        @map("reviewer_id") @db.Uuid
  note        String?       @db.Text
  reviewedAt  DateTime      @default(now()) @map("reviewed_at")

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  reviewer User @relation(fields: [reviewerId], references: [id])

  @@index([taskId, reviewedAt])
  @@map("qc_reviews")
}

model PaymentSchedule {
  id                   String        @id @default(uuid()) @db.Uuid
  projectId            String        @map("project_id") @db.Uuid
  phaseNumber          Int           @map("phase_number")
  milestoneDescription String        @map("milestone_description")
  percent              Decimal       @db.Decimal(5, 2)
  amount               Decimal       @db.Decimal(15, 2)
  expectedDate         DateTime      @map("expected_date") @db.Date
  dayOffset            Int           @map("day_offset")
  status               PaymentStatus @default(not_collected)
  actualPaidDate       DateTime?     @map("actual_paid_date") @db.Date
  actualPaidAmount     Decimal?      @map("actual_paid_amount") @db.Decimal(15, 2)
  notes                String?       @db.Text
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, phaseNumber])
  @@index([status])
  @@index([expectedDate])
  @@map("payment_schedules")
}

model ProjectMember {
  id            String            @id @default(uuid()) @db.Uuid
  projectId     String            @map("project_id") @db.Uuid
  userId        String            @map("user_id") @db.Uuid
  roleInProject ProjectMemberRole @map("role_in_project")
  addedAt       DateTime          @default(now()) @map("added_at")
  addedBy       String            @map("added_by") @db.Uuid

  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User    @relation(fields: [userId], references: [id])
  addedByUser User    @relation("ProjectMemberAddedBy", fields: [addedBy], references: [id])

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_members")
}

model ProjectMemberAssignment {
  id         String          @id @default(uuid()) @db.Uuid
  projectId  String          @map("project_id") @db.Uuid
  userId     String          @map("user_id") @db.Uuid
  role       ProjectRoleType
  isPrimary  Boolean         @default(false) @map("is_primary")
  assignedAt DateTime        @default(now()) @map("assigned_at")
  assignedBy String          @map("assigned_by") @db.Uuid

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user     User    @relation("ProjectAssignmentUser", fields: [userId], references: [id])
  assigner User    @relation("ProjectAssignmentAssigner", fields: [assignedBy], references: [id])

  @@unique([projectId, userId, role])
  @@index([projectId])
  @@index([userId])
  @@map("project_member_assignments")
}

model SiteRestDay {
  id         String         @id @default(uuid()) @db.Uuid
  projectId  String         @map("project_id") @db.Uuid
  restDate   DateTime       @map("rest_date") @db.Date
  reason     SiteRestReason
  note       String?
  declaredBy String         @map("declared_by") @db.Uuid
  createdAt  DateTime       @default(now()) @map("created_at")

  project        Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  declaredByUser User    @relation(fields: [declaredBy], references: [id])

  @@unique([projectId, restDate])
  @@index([projectId, restDate])
  @@map("site_rest_days")
}

model MorningReport {
  id          String     @id @default(uuid()) @db.Uuid
  projectId   String     @map("project_id") @db.Uuid
  reporterId  String     @map("reporter_id") @db.Uuid
  reportDate  DateTime   @map("report_date") @db.Date
  submittedAt DateTime?  @map("submitted_at")
  isOnTime    Boolean    @default(false) @map("is_on_time")
  overallNote String?    @map("overall_note") @db.Text
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  project       Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reporter      User                @relation(fields: [reporterId], references: [id])
  taskReports   MorningReportTask[]
  eveningReport EveningReport?

  @@unique([projectId, reportDate, reporterId])
  @@index([projectId, reportDate])
  @@map("morning_reports")
}

model MorningReportTask {
  id              String         @id @default(uuid()) @db.Uuid
  morningReportId String         @map("morning_report_id") @db.Uuid
  taskId          String         @map("task_id") @db.Uuid
  decision        ReportDecision
  plannedActivity String?        @map("planned_activity") @db.Text
  pauseReason     PauseReason?   @map("pause_reason")
  pauseNote       String?        @map("pause_note") @db.Text
  createdAt       DateTime       @default(now()) @map("created_at")

